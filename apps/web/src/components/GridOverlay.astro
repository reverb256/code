---
interface Props {
  visible?: boolean;
}

const { visible = true } = Astro.props;
---
{visible && (
  <div class="grid-overlay" aria-hidden="true">
    <div class="grid-overlay-inner">
      <div class="grid-rail rail-1"><span>1</span></div>
      <div class="grid-rail rail-2"><span>2</span></div>
      <div class="grid-rail rail-3"><span>3</span></div>
      <div class="grid-rail rail-4"><span>4</span></div>
      <div class="grid-rail rail-5"><span>5</span></div>
    </div>
  </div>
)}
