---
import DottedContainer from "../components/DottedContainer.astro";
import GridOverlay from "../components/GridOverlay.astro";
import Base from "../layouts/Base.astro";
import "../styles/playground.css";

const sizes = [
  { class: "type-5xl", label: "5xl" },
  { class: "type-4xl", label: "4xl" },
  { class: "type-3xl", label: "3xl" },
  { class: "type-2xl", label: "2xl" },
  { class: "type-xl", label: "xl" },
  { class: "type-lg", label: "lg" },
  { class: "type-base", label: "base" },
  { class: "type-sm", label: "sm" },
  { class: "type-xs", label: "xs" },
];

const weights = [
  { class: "weight-thin", label: "Thin", value: "100" },
  { class: "weight-light", label: "Light", value: "300" },
  { class: "weight-regular", label: "Regular", value: "400" },
  { class: "weight-medium", label: "Medium", value: "500" },
  { class: "weight-semibold", label: "Semibold", value: "600" },
  { class: "weight-bold", label: "Bold", value: "700" },
  { class: "weight-black", label: "Black", value: "900" },
];
---
<Base title="Playground" debug>
  <GridOverlay labels />

  <section class="grid-container grid-section">
    <header class="section-header cell-pad">
      <h1 class="type-2xl weight-bold">Playground</h1>
      <p class="type-sm">Typography & Grid System</p>
    </header>
    <nav class="section-body cell-pad playground-nav">
      <a href="#typography" class="type-sm">Typography</a>
      <a href="#grid" class="type-sm">Grid</a>
    </nav>
  </section>

  <section id="typography" class="grid-container grid-section border-t">
    <div class="section-header cell-pad">
      <h2 class="type-xl weight-bold">Type Scale</h2>
    </div>
    <div class="section-body--wide cell-pad">
      {sizes.map(({ class: cls, label }) => (
        <div class="type-row">
          <span class="type-label type-xs">{label}</span>
          <span class={cls}>The quick brown fox</span>
        </div>
      ))}
    </div>
  </section>

  <section class="grid-container grid-section border-t">
    <div class="section-header cell-pad">
      <h2 class="type-xl weight-bold">Weights</h2>
    </div>
    <div class="section-body cell-pad">
      {weights.map(({ class: cls, label, value }) => (
        <div class="type-row">
          <span class="type-label type-xs">{value}</span>
          <span class={`type-lg ${cls}`}>{label}</span>
        </div>
      ))}
    </div>
  </section>

  <section id="grid" class="grid-container grid-section grid-section--spacious border-t">
    <div class="section-header cell-pad">
      <h2 class="type-xl weight-bold">Grid</h2>
      <p class="type-sm">5 rails on desktop, 3 on tablet, 1 on mobile</p>
    </div>
    <div class="section-body--wide cell-pad">
      <p class="type-base">This content spans columns 2-4 on desktop using <code class="demo-code">.section-body--wide</code></p>
    </div>
  </section>

  <section class="grid-container grid-section grid-demo border-t">
    <div class="col-1 cell-pad rail-tick-start rail-tick-end">
      <span class="type-xs">1</span>
    </div>
    <div class="col-2 cell-pad rail-tick-start rail-tick-end playground-col-2">
      <span class="type-xs">2</span>
    </div>
    <div class="col-3 cell-pad rail-tick-start rail-tick-end playground-col-3">
      <span class="type-xs">3</span>
    </div>
    <div class="col-4 cell-pad rail-tick-start rail-tick-end playground-col-4">
      <span class="type-xs">4</span>
    </div>
    <div class="col-5 cell-pad rail-tick-start rail-tick-end playground-col-5">
      <span class="type-xs">5</span>
    </div>
  </section>

  <section class="grid-container grid-section border-t">
    <div class="section-header cell-pad">
      <h2 class="type-lg weight-bold">Spans</h2>
    </div>
    <div class="col-span-2 cell-pad demo-cell playground-span-2">
      <span class="type-xs">span 2</span>
    </div>
    <div class="col-span-3 cell-pad demo-cell playground-span-3">
      <span class="type-xs">span 3</span>
    </div>
    <div class="col-full cell-pad demo-cell">
      <span class="type-xs">full width</span>
    </div>
  </section>

  <section class="grid-container grid-section border-t">
    <div class="section-header cell-pad">
      <h2 class="type-lg weight-bold">Bleed</h2>
    </div>
    <div class="col-full">
      <div class="full-bleed demo-bleed">
        <span class="type-xs cell-pad">.full-bleed — extends to viewport edges</span>
      </div>
    </div>
  </section>

  <section class="grid-container grid-section border-t">
    <div class="section-header cell-pad">
      <h2 class="type-lg weight-bold">Images</h2>
    </div>
    <div class="section-body cell-pad">
      <figure class="image-figure">
        <img src="/branch.svg" alt="Branch illustration" class="image-contained" />
        <figcaption class="type-xs">.image-contained — fits within column</figcaption>
      </figure>
    </div>
    <div class="section-aside cell-pad">
      <p class="type-sm">Images can be placed in any grid column using the section roles.</p>
    </div>
  </section>

  <section class="grid-container grid-section border-t">
    <div class="section-header cell-pad">
      <h2 class="type-lg weight-bold">Bleed Start</h2>
    </div>
    <div class="col-1 image-bleed-start">
      <img src="/branch.svg" alt="Branch illustration" />
    </div>
  </section>

  <section class="grid-container grid-section border-t">
    <div class="section-header cell-pad">
      <h2 class="type-lg weight-bold">Buttons</h2>
    </div>
    <div class="section-body cell-pad button-demo">
      <div class="button-row">
        <button class="btn btn-solid">Solid</button>
        <button class="btn btn-outline">Outline</button>
      </div>
      <div class="button-row">
        <button class="btn btn-solid" disabled>Solid Disabled</button>
        <button class="btn btn-outline" disabled>Outline Disabled</button>
      </div>
    </div>
  </section>

  <section class="grid-container grid-section border-t">
    <div class="section-header cell-pad">
      <h2 class="type-lg weight-bold">Dotted Container</h2>
    </div>
    <div class="section-body cell-pad" style="display: flex; flex-direction: column; gap: 2rem;">
      <DottedContainer>
        <span slot="title">Cost calculator</span>
        <p class="type-base">Content with a title</p>
      </DottedContainer>

      <DottedContainer>
        <span slot="title">Case study</span>
        <p class="type-base">Content with title and action button</p>
        <a href="#" slot="action">Case study &rarr;</a>
      </DottedContainer>

      <DottedContainer>
        <p class="type-base">Content without a title</p>
      </DottedContainer>
    </div>
  </section>
</Base>
