---
import Base from "../layouts/Base.astro";

const sizes = [
  { class: "type-5xl", label: "5xl", var: "--type-5xl" },
  { class: "type-4xl", label: "4xl", var: "--type-4xl" },
  { class: "type-3xl", label: "3xl", var: "--type-3xl" },
  { class: "type-2xl", label: "2xl", var: "--type-2xl" },
  { class: "type-xl", label: "xl", var: "--type-xl" },
  { class: "type-lg", label: "lg", var: "--type-lg" },
  { class: "type-base", label: "base", var: "--type-base" },
  { class: "type-sm", label: "sm", var: "--type-sm" },
  { class: "type-xs", label: "xs", var: "--type-xs" },
];

const weights = [
  { class: "weight-thin", label: "Thin", value: "100" },
  { class: "weight-light", label: "Light", value: "300" },
  { class: "weight-regular", label: "Regular", value: "400" },
  { class: "weight-medium", label: "Medium", value: "500" },
  { class: "weight-semibold", label: "Semibold", value: "600" },
  { class: "weight-bold", label: "Bold", value: "700" },
  { class: "weight-black", label: "Black", value: "900" },
];
---
<Base title="Typography Playground">
  <main>
    <header>
      <h1 class="type-2xl weight-bold">Typography</h1>
      <p class="type-sm">TX-02 → JetBrains Mono → system mono</p>
    </header>

    <section>
      <h2 class="type-lg weight-bold">Type Scale</h2>
      <div class="scale-grid">
        {sizes.map(({ class: cls, label, var: cssVar }) => (
          <div class="scale-row">
            <span class="scale-label type-xs">{label}</span>
            <span class={cls}>The quick brown fox</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="type-lg weight-bold">Font Weights</h2>
      <div class="weight-grid">
        {weights.map(({ class: cls, label, value }) => (
          <div class="weight-row">
            <span class="weight-label type-xs">{value}</span>
            <span class={`type-xl ${cls}`}>{label}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="type-lg weight-bold">Combined</h2>
      <p class="type-3xl weight-thin">Thin 3xl</p>
      <p class="type-2xl weight-light">Light 2xl</p>
      <p class="type-xl weight-regular">Regular xl</p>
      <p class="type-lg weight-medium">Medium lg</p>
      <p class="type-base weight-semibold">Semibold base</p>
      <p class="type-sm weight-bold">Bold sm</p>
      <p class="type-xs weight-black">Black xs</p>
    </section>
  </main>
</Base>

<style>
  main {
    max-width: 90rem;
    margin-inline: auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .scale-grid,
  .weight-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .scale-row,
  .weight-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
  }

  .scale-label,
  .weight-label {
    width: 3rem;
    flex-shrink: 0;
    opacity: 0.5;
  }
</style>
