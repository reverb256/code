---
import Base from "../layouts/Base.astro";
import GridOverlay from "../components/GridOverlay.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const chapters = [
  {
    title: "getting started",
    sections: ["installation", "system requirements", "quick start"],
  },
  {
    title: "core concepts",
    sections: ["agentic development", "workspaces", "posthog integration", "glossary"],
  },
  {
    title: "using twig",
    sections: ["interface overview", "opening projects", "working with the agent", "code editing", "terminal", "keyboard shortcuts", "settings"],
  },
  {
    title: "posthog features",
    sections: ["connecting posthog"],
  },
  {
    title: "troubleshooting",
    sections: ["installation issues", "connection issues"],
  },
  {
    title: "advanced",
    sections: ["model context protocol"],
  },
  {
    title: "pricing",
    sections: [],
  },
];
