      <nav class="manual-nav cell-pad scrollbar-styled">
        <h1 class="type-xl manual-nav-title">Manual</h1>
        <ol class="manual-toc">
          {chapters.map((chapter, index) => (
            <li class="manual-toc-chapter">
              <a href={`#chapter-${index + 1}`} class="manual-toc-link type-sm weight-medium">
                <span class="manual-toc-number">{index + 1}.</span><span class="manual-toc-title">{chapter.title}</span>
              </a>
              {chapter.sections.length > 0 && (
                <ul class="manual-toc-sections">
                  {chapter.sections.map((section) => (
                    <li>
                      <a href={`#${section.toLowerCase().replace(/\s+/g, "-")}`} class="manual-toc-section-link type-xs">
                        {section}
                      </a>
                    </li>
