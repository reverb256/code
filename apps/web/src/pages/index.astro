---
import DottedContainer from "../components/DottedContainer.astro";
import Footer from "../components/Footer.astro";
import GridOverlay from "../components/GridOverlay.astro";
import Header from "../components/Header.astro";
import WaitlistForm from "../components/WaitlistForm.astro";
import Base from "../layouts/Base.astro";

const WAVE_BARS = Array.from({ length: 12 });
---

<Base title="twig — the ai editor that understands your product">
  <GridOverlay />
  <Header accent />

  <!-- ════════════════════════
       HERO
  ════════════════════════ -->
  <section class="hero-section">
    <div class="grid-container">
      <div class="hero-left cell-pad">
        <h1 class="type-3xl lh-tight">where product signals become shipped code</h1>
        <div class="hero-inline-form">
          <span class="type-xs weight-bold fig-label" style="margin-bottom: var(--space-xs)">get early access</span>
          <WaitlistForm />
        </div>
      </div>
      <div class="hero-right cell-pad">
        <p class="type-sm">At posthog, we've spent years building tools that help teams understand their users. Product analytics, session recordings, feature flags, a/b testing — all designed to answer one fundamental question: what do your users actually do?</p>
        <p class="type-sm">Then we looked at how software gets built, and something struck us as deeply wrong.</p>
        <p class="type-sm">code editors are stupid.</p>
        <p class="type-sm" style="opacity: 0.6">Not in capability – the latest generation of ai-powered editors are remarkably capable at writing code. They just have absolutely no idea what your product actually is, or what your users need.</p>
        <p class="type-sm">we're building the solution: it's called product autonomy, and it starts with twig.</p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════
       CALLOUT STRIP
  ════════════════════════ -->
  <div class="callout-strip">
    <div class="grid-container">
      <div class="callout-strip-inner cell-pad">
        <span class="type-xs weight-bold" style="letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.6">from the makers of PostHog</span>
        <span class="type-xs" style="opacity: 0.5">the open-source product analytics platform used by 200,000+ teams</span>
      </div>
    </div>
  </div>


  <!-- ════════════════════════
       TWIG AGENTS
  ════════════════════════ -->
  <section class="grid-container grid-section">
    <div class="col-full fig-section">
      <div class="fig-header cell-pad">
        <span class="fig-header-id">[ FIG.1.1 ]</span>
        <span class="fig-header-sub">What is twig</span>
      </div>
      <div class="fig-body fig-body--three-col">
        <div class="fig-cell stat-col stat-col--bugs">
          <h2>background agents</h2>
          <p class="type-sm" style="opacity: 0.75">Most agents are reactive, you tell them what to do, which kind of sucks. With PostHog's data, we can make agents proactive. They surface and fix issues before you even know to ask.</p>
        </div>
        <div class="fig-cell stat-col stat-col--hours">
          <h2>agent orchestrator</h2>
          <p class="type-sm" style="opacity: 0.75">Spin up infinite Codex + Claude Code agents in isolated git worktrees. Tasks come with context pre-loaded, execution happens in the background, and you review/iterate all in one place. It's the coordination layer that's currently missing</p>
        </div>
        <div class="fig-cell stat-col stat-col--branches">
          <h2>agentic coding</h2>
          <p class="type-sm" style="opacity: 0.75">Use the exact same AI models and harnesses you already use, at the same prices.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════
       FIG 1.2 — ROOT CAUSE ANALYSIS
  ════════════════════════ -->
  <section class="grid-container grid-section">
    <div class="col-full fig-section">
      <div class="fig-header cell-pad">
        <span class="fig-header-id">[ FIG.1.2 ]</span>
        <span class="fig-header-sub">the coordination layer for many agents working in parallel</span>
      </div>
      <div class="fig-body fig-body--three-col">

        <!-- Problem copy -->
        <div class="fig-cell">
          <h2 class="type-xl weight-bold">root cause analysis that ends with a merged branch</h2>
          <p class="type-sm" style="opacity: 0.8; margin-bottom: var(--space-sm)">Codex, Claude Code, and similar tools accelerate code generation, but you always make the first move.</p>
          <p class="type-sm" style="opacity: 0.8">Twig works 24/7 to determine what matters right now, runs autonomous work against it, and hands you contextual code to merge, kill or iterate on.</p>
        </div>

        <!-- Branch diagram -->
        <div class="fig-cell fig-cell--shaded fig-cell--flex-center">
          <div class="branch-list">
            <div class="branch-row">
              <span class="branch-dot" style="color: #4D642C">●</span>
              <span class="branch-name">fix/checkout-null-error</span>
              <span class="branch-badge branch-badge--merged">MERGED</span>
            </div>
            <div class="branch-row" style="opacity: 0.75">
              <span class="branch-dot" style="color: var(--color-accent)">●</span>
              <span class="branch-name">feat/dark-mode-prototype</span>
              <span class="branch-badge branch-badge--review">REVIEW</span>
            </div>
            <div class="branch-row" style="opacity: 0.55">
              <span class="branch-dot" style="color: #083E67">●</span>
              <span class="branch-name" style="border-style: dashed">perf/pricing-page-lcp</span>
              <span class="branch-badge branch-badge--running">RUNNING</span>
            </div>
            <div class="branch-row" style="opacity: 0.35">
              <span class="branch-dot">●</span>
              <span class="branch-name" style="border-style: dashed">fix/signup-form-a11y</span>
              <span class="branch-badge branch-badge--queued">QUEUED</span>
            </div>
            <div class="branch-row" style="opacity: 0.2">
              <span class="branch-dot">●</span>
              <span class="branch-name" style="border-style: dashed">chore/update-deps</span>
              <span class="branch-badge branch-badge--queued">QUEUED</span>
            </div>
            <div class="branch-footer type-xs">3 agents running · 8 daily limit remaining</div>
          </div>
        </div>

        <!-- Specimen hover -->
        <div class="fig-cell fig-cell--shaded specimen-cell">
          <div class="specimen-cell-image specimen-cell-image--branch">
            <img src="/branch.svg" alt="" class="specimen-img" />
          </div>
          <div class="specimen-caption" aria-hidden="true">
            <span class="specimen-label-id">Twig agents work in seperate worktrees</span>
            <p class="specimen-label-name">you didn't become an engineer to manage merge conflicts</p>
          </div>
        </div>

      </div>
    </div>
  </section>




  <!-- ════════════════════════
       SIGNALS → PRS
  ════════════════════════ -->
  <section class="grid-container grid-section">
    <div class="col-full fig-section">
      <div class="fig-header cell-pad">
        <span class="fig-header-id">[ FIG.1.2 ]</span>
        <span class="fig-header-sub">introduce fewer bugs. smart rollouts that minimise blast radius automatically.</span>
      </div>
      <div class="fig-body fig-body--two-col">

        <!-- Specimen B -->
        <div class="fig-cell fig-cell--shaded specimen-cell">
          <div class="specimen-cell-image specimen-cell-image--tree">
            <img src="/tree.svg" alt="" class="specimen-img" />
          </div>
          <div class="specimen-caption" aria-hidden="true">
            <span class="specimen-label-id">Wake up to the boring work already done</span>
            <p class="specimen-label-name">Twig background agents fix bugs and carry out rote maintenance while your sleep</p>
          </div>
        </div>

        <!-- PR card (cycles through 3 variants) -->
        <div class="fig-cell">
          <h2 class="type-xl weight-bold">an agent without context is just autocomplete</h2>
          <p class="type-sm" style="opacity: 0.8">twig has the exact same coding capabilities as everyone else, but it understands your users. It fixes bugs, finds UX issues with computer vision, responds to feedback — so you are left with an inbox of work already done for you.</p>
          <div class="pr-card-cycler">
            <div class="pr-card-track">
            <div class="pr-card pr-card-variant">
              <div class="pr-card-header">
                <span class="type-xs weight-bold" style="letter-spacing: 0.08em; text-transform: uppercase">pull request #1847</span>
              </div>
              <div class="pr-card-title">
                <h3>fix: null ref on payment step when session has no user</h3>
                <p>Checkout was throwing when the session had no user (e.g. returning to a stale tab). 24 users hit the error in the last 2 hours. Add a guard so we redirect to login.</p>
              </div>
              <div class="pr-card-diff">
                <div class="diff-remove">-  const email = user.email;</div>
                <div class="diff-add">+  if (!user) return &lt;Redirect to="/login" /&gt;;</div>
                <div class="diff-add">+  const email = user.email ?? "";</div>
                <div class="diff-comment">// twig: checkout funnel drop + Sentry getBillingEmail null ref</div>
              </div>
            </div>
            <div class="pr-card pr-card-variant">
              <div class="pr-card-header">
                <span class="type-xs weight-bold" style="letter-spacing: 0.08em; text-transform: uppercase">pull request #1921</span>
              </div>
              <div class="pr-card-title">
                <h3>fix: export fails when date range has no data</h3>
                <p>Reports export was throwing when the selected range was empty. Users saw a generic error. Add an empty state and disable the export button when there's nothing to export.</p>
              </div>
              <div class="pr-card-diff">
                <div class="diff-remove">-  const csv = generateReport(data);</div>
                <div class="diff-add">+  if (!data.length) return &lt;EmptyState message="No data in this range" /&gt;;</div>
                <div class="diff-add">+  const csv = generateReport(data);</div>
                <div class="diff-comment">// twig: support ticket + Sentry generateReport empty array</div>
              </div>
            </div>
            <div class="pr-card pr-card-variant">
              <div class="pr-card-header">
                <span class="type-xs weight-bold" style="letter-spacing: 0.08em; text-transform: uppercase">pull request #1954</span>
              </div>
              <div class="pr-card-title">
                <h3>fix: signup form double-submit on slow networks</h3>
                <p>On slow connections users could submit twice and end up with duplicate accounts. Disable the button after first click and show a loading state until the request completes.</p>
              </div>
              <div class="pr-card-diff">
                <div class="diff-remove">-  &lt;button onClick=&#123;handleSubmit&#125;&gt;Create account&lt;/button&gt;</div>
                <div class="diff-add">+  &lt;button onClick=&#123;handleSubmit&#125; disabled=&#123;isSubmitting&#125;&gt;</div>
                <div class="diff-add">+    &#123;isSubmitting ? "Creating…" : "Create account"&#125;&lt;/button&gt;</div>
                <div class="diff-comment">// twig: duplicate signup events in PostHog</div>
              </div>
            </div>
            </div>
            <nav class="pr-card-nav" aria-label="PR examples">
              <button type="button" class="pr-card-dot" data-slide="0" aria-label="Example 1: payment step fix"></button>
              <button type="button" class="pr-card-dot" data-slide="1" aria-label="Example 2: export empty range"></button>
              <button type="button" class="pr-card-dot" data-slide="2" aria-label="Example 3: signup double-submit"></button>
            </nav>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll(".pr-card-cycler").forEach((cyclerEl) => {
      const cycler = cyclerEl as HTMLElement;
      const dots = cycler.querySelectorAll(".pr-card-dot");
      dots.forEach((btnEl) => {
        const btn = btnEl as HTMLElement;
        btn.addEventListener("click", () => {
          const slide = parseInt(btn.dataset.slide ?? "0", 10);
          cycler.classList.add("pr-cycler-paused");
          cycler.style.setProperty("--pr-slide", String(slide));
          dots.forEach((dEl, i) => {
            const d = dEl as HTMLElement;
            d.classList.toggle("active", i === slide);
            d.setAttribute("aria-current", i === slide ? "true" : "false");
          });
        });
      });
    });
  </script>


  <!-- ════════════════════════
       INTEGRATION STRIP
  ════════════════════════ -->
  <div class="integration-strip compact-spacing">
    <div class="integration-strip-inner cell-pad">
      <DottedContainer class="integration-strip-container">
        <span class="type-xs weight-bold" style="letter-spacing: 0.08em; flex-shrink: 0">TWIG INGESTS SIGNALS FROM</span>
        <span class="integration-badge">○ PostHog</span>
        <span class="integration-badge">○ GitHub</span>
        <span class="integration-badge">○ Granola</span>
        <span class="integration-badge">○ Slack</span>
        <span class="integration-badge">⬡ Linear</span>
        <span class="integration-badge">○ Sentry</span>
        <span class="integration-badge">○ Notion</span>
        <span class="integration-badge">○ Zendesk</span>
        <span class="data-source-badge data-source-badge--more">+ any MCP</span>
      </DottedContainer>
    </div>
  </div>
  
  <!-- ════════════════════════
       DATA — SOURCES + MODELS
  ════════════════════════ -->
  <section class="grid-container grid-section">
    <div class="col-full fig-section">
      <div class="fig-header cell-pad">
        <span class="fig-header-id">[ FIG.1.2 ]</span>
        <span class="fig-header-sub">it's not just posthog data, it's everything</span>
      </div>
      <div class="fig-body fig-body--two-col">

        <!-- Copy + wizard -->
        <div class="fig-cell">
          <h2 class="type-xl weight-bold">twig connects to your whole stack</h2>
          <p class="type-sm" style="opacity: 0.8; margin-bottom: var(--space-md)">It's not just product data, it's everything. Devtools, databases, and tickets flow into the same signals engine. twig processes noisy unstructured data, decides most of it doesn't matter, and surfaces the small percentage that actually does.</p>
          <div class="inbox-dark-wrap">
            <div class="inbox-ui">
              <div class="inbox-ui-header">
                <span><span class="inbox-ui-header-dot"></span>twig / signals inbox</span>
                <span class="inbox-ui-header-status">5 agents running</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">checkout funnel — 40% drop at payment step</div>
                  <div class="inbox-signal-meta">PostHog · 2,340 sessions · trending up · 3h ago</div>
                </div>
                <span class="inbox-badge inbox-badge--running">agent running</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">TypeError: Cannot read properties of undefined</div>
                  <div class="inbox-signal-meta">Sentry · 847 occurrences · 12 users affected · 1h ago</div>
                </div>
                <span class="inbox-badge inbox-badge--done">PR open</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">BUG-421 — P0 regression in export flow, 4 comments</div>
                  <div class="inbox-signal-meta">Linear · linked to Sentry · reopened 2h ago</div>
                </div>
                <span class="inbox-badge inbox-badge--high">high priority</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">#customer-feedback — "export has been broken for 2 days"</div>
                  <div class="inbox-signal-meta">Slack · 8 messages · last 6h</div>
                </div>
                <span class="inbox-badge inbox-badge--waiting">queued</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">dependency audit — 2 high, 5 moderate · main branch</div>
                  <div class="inbox-signal-meta">GitHub · 3 PRs stale &gt; 5 days · 12 commits behind</div>
                </div>
                <span class="inbox-badge inbox-badge--waiting">queued</span>
              </div>
              <div class="inbox-ui-footer">+ 14 more signals from PostHog, Slack, Linear, GitHub, Sentry · 2 agents at daily limit</div>
            </div>
          </div>
        </div>

        <!-- Specimen D -->
        <div class="fig-cell fig-cell--shaded specimen-cell">
          <div class="specimen-cell-image specimen-cell-image--clouds">
            <img src="/clouds-2.svg" alt="" class="specimen-img" />
          </div>
          <div class="specimen-caption" aria-hidden="true">
            <span class="specimen-label-id">Like a spam filter for your product inbox</span>
            <p class="specimen-label-name">Gmail doesn't show you every email — it filters, ranks, and surfaces what matters. twig does the same for the stream of data your product generates.</p>
          </div>
        </div>

        <!-- How it works — inverted 4-step pipeline -->
        <div class="fig-cell fig-cell--border-top fig-cell--full how-it-works-row">
          <p>how twig works (mostly without you)</p>
          <div class="how-pipeline" aria-hidden="true">
            <div class="how-pipeline-runner"></div>
          </div>
          <div class="how-steps">
            <div class="how-step">
              <span class="how-step-num">01 —</span>
              <h3 class="how-step-title">signals come in</h3>
              <p>twig pulls from PostHog, GitHub, Linear, Slack, Sentry — wherever your product leaves traces. errors, drop-offs, stale flags, support threads. raw noise.</p>
            </div>
            <div class="how-step">
              <span class="how-step-num">02 —</span>
              <h3 class="how-step-title">clusters form</h3>
              <p>related signals group together. when enough evidence accumulates, twig surfaces a ranked report — a credible hypothesis, not just another alert.</p>
            </div>
            <div class="how-step">
              <span class="how-step-num">03 —</span>
              <h3 class="how-step-title">agents run</h3>
              <p>for the highest-priority signals, twig spins up coding agents automatically — up to the daily limit you set. your repo, not some sandbox.</p>
            </div>
            <div class="how-step">
              <span class="how-step-num">04 —</span>
              <h3 class="how-step-title">you decide</h3>
              <p>agents bring you a PR, an explanation, and a recommendation. you merge, reject, or keep the conversation going. the judgment is yours.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

   

  <!-- ════════════════════════
       FIG 1.5 — WHAT TWIG IS NOT
  ════════════════════════ -->
  <section class="grid-container grid-section">
    <div class="col-full fig-section">
      <div class="fig-header cell-pad">
        <span class="fig-header-id">[ FIG.1.5 ]</span>
        <span class="fig-header-sub">what twig is not</span>
      </div>
      <div class="fig-body fig-body--three-col">
        <div class="fig-cell">
          <span class="not-label">× not another dashboard</span>
          <h3 class="type-base weight-bold" style="margin-bottom: var(--space-sm)">signals become tasks, not graphs</h3>
          <p class="type-sm" style="opacity: 0.75">Most work in twig happens in the signals inbox and agent chat. PostHog and twig link product analytics for when you need a different view.</p>
          <a href="https://posthog.com/product-analytics" class="box-button">show me some charts →</a>
        </div>
        <div class="fig-cell">
          <span class="not-label">× not a new model harness</span>
          <h3 class="type-base weight-bold" style="margin-bottom: var(--space-sm)">claude code x infinity</h3>
          <p class="type-sm" style="opacity: 0.75">Use the exact same AI models and harnesses you already use, at the same prices.</p>
          <div class="hero-model-options" role="group" aria-label="Model provider">
            <span class="hero-model-option" title="Google Gemini">
              <img src="/gemini-logo.svg" alt="Google Gemini" width="40" height="40" />
            </span>
            <span class="hero-model-option" title="OpenAI">
              <img src="/chatgpt-openai_logo.svg" alt="OpenAI" width="40" height="40" />
            </span>
            <span class="hero-model-option" title="Anthropic Claude">
              <img src="/claude-logo.svg" alt="Anthropic Claude" width="40" height="40" />
            </span>
          </div>
        </div>
        <div class="fig-cell">
          <span class="not-label">× not a no-code tool</span>
          <h3 class="type-base weight-bold" style="margin-bottom: var(--space-sm)">write code (if you want to)</h3>
          <p class="type-sm" style="opacity: 0.75">Orchestrate twig agents to build big features. Hardcore user of another IDE? You'll get the best experience in twig, but if you insist:</p>
          <div class="mcp-block">
            <code class="mcp-code">npx @posthog/twig-mcp</code>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════
       SPAM FILTER
  ════════════════════════ -->
  <section class="grid-container grid-section">
    <div class="col-full fig-section">
      <div class="fig-header cell-pad">
        <span class="fig-header-id">[ FIG.1.2 ]</span>
        <span class="fig-header-sub">seek and destroy bugs with background agents</span>
      </div>
      <div class="fig-body fig-body--two-col">

        <!-- spam filter product inbox-->
        <div class="fig-cell">
          <h2 class="type-xl weight-bold">like a spam filter for engineering work</h2>
          <p class="type-sm" style="opacity: 0.8; margin-bottom: var(--space-md)">Gmail doesn't show you every email — it filters, ranks, and surfaces what matters. twig does the same for the stream of data your product generates.</p>
          <div class="inbox-dark-wrap">
            <div class="inbox-ui">
              <div class="inbox-ui-header">
                <span><span class="inbox-ui-header-dot"></span>twig / signals inbox</span>
                <span class="inbox-ui-header-status">5 agents running</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">checkout funnel — 40% drop at payment step</div>
                  <div class="inbox-signal-meta">PostHog · 2,340 sessions · trending up · 3h ago</div>
                </div>
                <span class="inbox-badge inbox-badge--running">agent running</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">TypeError: Cannot read properties of undefined</div>
                  <div class="inbox-signal-meta">Sentry · 847 occurrences · 12 users affected · 1h ago</div>
                </div>
                <span class="inbox-badge inbox-badge--done">PR open</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">BUG-421 — P0 regression in export flow, 4 comments</div>
                  <div class="inbox-signal-meta">Linear · linked to Sentry · reopened 2h ago</div>
                </div>
                <span class="inbox-badge inbox-badge--high">high priority</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">#customer-feedback — "export has been broken for 2 days"</div>
                  <div class="inbox-signal-meta">Slack · 8 messages · last 6h</div>
                </div>
                <span class="inbox-badge inbox-badge--waiting">queued</span>
              </div>
              <div class="inbox-ui-row">
                <div>
                  <div class="inbox-signal-title">dependency audit — 2 high, 5 moderate · main branch</div>
                  <div class="inbox-signal-meta">GitHub · 3 PRs stale &gt; 5 days · 12 commits behind</div>
                </div>
                <span class="inbox-badge inbox-badge--waiting">queued</span>
              </div>
              <div class="inbox-ui-footer">+ 14 more signal reports · 2 agents at daily limit</div>
            </div>
          </div>
        </div>

        <!-- Specimen D -->
        <div class="fig-cell fig-cell--shaded specimen-cell">
          <div class="specimen-cell-image specimen-cell-image--bugs-grid">
            <img src="/bugs-grid-1.svg" alt="" class="specimen-img" />
          </div>
          <div class="specimen-caption" aria-hidden="true">
            <span class="specimen-label-id">Like a spam filter for your product inbox</span>
            <p class="specimen-label-name">Gmail doesn't show you every email — it filters, ranks, and surfaces what matters. twig does the same for the stream of data your product generates.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════
       FIG 1.3 — PARALLEL AGENTS
  ════════════════════════ -->
  <section class="grid-container grid-section">
    <div class="col-full fig-section">
      <div class="fig-header cell-pad">
        <span class="fig-header-id">[ FIG.1.3 ]</span>
        <span class="fig-header-sub">parallel agents across independent git worktrees</span>
      </div>
      <div class="fig-body fig-body--two-col">

