{
  "name": "@posthog/ui",
  "version": "1.0.0",
  "description": "Shared UI components for Twig apps",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./conversation": {
      "types": "./dist/conversation/buildConversationItems.d.ts",
      "import": "./dist/conversation/buildConversationItems.js"
    },
    "./types": {
      "types": "./dist/types/session-events.d.ts",
      "import": "./dist/types/session-events.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@phosphor-icons/react": ">=2.0.0",
    "@radix-ui/themes": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-markdown": ">=10.0.0",
    "remark-breaks": ">=4.0.0",
    "remark-gfm": ">=4.0.0"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.14.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/themes": "^3.2.1",
    "@types/react": "^19.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ]
}
